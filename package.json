{
  "name": "pi-inter-agent",
  "version": "0.1.0",
  "description": "Pi extension for connecting to the inter-agent message bus",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/index.ts package.json README.md"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "inter-agent",
    "message-bus",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "author": "Nicholas Moen",
  "license": "MIT",
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
